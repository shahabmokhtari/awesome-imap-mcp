{
  "name": "ultimate-imap-mcp",
  "version": "0.1.0",
  "description": "Batteries-included MCP server for email with local cache, operation queue, web dashboard, and LLM analysis",
  "author": "Shahab",
  "license": "MIT",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm -r --parallel dev",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "start": "node packages/mcp-server/dist/index.js",
    "setup": "node packages/mcp-server/dist/setup.js",
    "dashboard": "node packages/dashboard/dist/server/index.js"
  },
  "bin": {
    "ultimate-imap-mcp": "./packages/mcp-server/dist/index.js"
  },
  "keywords": [
    "mcp",
    "imap",
    "email",
    "claude",
    "model-context-protocol",
    "smtp",
    "gmail",
    "outlook"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/shahabganji/ultimate-imap-mcp"
  }
}
